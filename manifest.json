{
  "manifest_version": 3,
  "name": "Google Forms AI AutoFiller",
  "version": "0.1.0",
  "description": "Auto-answer Google Forms homework with Appwrite auth, credits, and OpenRouter AI.",
  "permissions": ["storage", "identity", "scripting", "activeTab"],
  "host_permissions": [
    "https://docs.google.com/forms/*",
    "https://fra.cloud.appwrite.io/v1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Forms AutoFiller"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
