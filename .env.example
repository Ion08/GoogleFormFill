# Extension defaults (store these in chrome.storage.af_config if needed)
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_FUNCTION_SOLVE_ID=
APPWRITE_DATABASE_ID=
APPWRITE_USERS_TABLE_ID=

# Appwrite Function env vars
APPWRITE_API_KEY=YOUR_SERVER_API_KEY
APPWRITE_TRANSACTIONS_TABLE_ID=
# OPENROUTER_API_KEY is the primary key name used by this project.
# PLATFORM_OPENROUTER_KEY is also accepted for compatibility.

PLATFORM_OPENROUTER_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=600000
OPENROUTER_MAX_RETRIES=2
STARTER_CREDITS=5
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_HOURS=1



GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

