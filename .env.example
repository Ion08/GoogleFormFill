# Extension defaults (store these in chrome.storage.af_config if needed)
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69b5015800281183d258
APPWRITE_FUNCTION_SOLVE_ID=YOUR_SOLVE_FORM_FUNCTION_ID
APPWRITE_DATABASE_ID=69b502620001c600ec4b
APPWRITE_USERS_TABLE_ID=users

# Appwrite Function env vars
APPWRITE_API_KEY=YOUR_SERVER_API_KEY
APPWRITE_TRANSACTIONS_TABLE_ID=transactions
# OPENROUTER_API_KEY is the primary key name used by this project.
# PLATFORM_OPENROUTER_KEY is also accepted for compatibility.

PLATFORM_OPENROUTER_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_MODEL=openai/gpt-4o-mini
STARTER_CREDITS=5
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_HOURS=1



GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

